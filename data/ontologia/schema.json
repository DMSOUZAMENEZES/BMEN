{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/DMSOUZAMENEZES/BMEN/data/ontologia/schema.json",
  "title": "BMEN Ontologia v1.x",
  "type": "object",
  "required": ["meta", "domains", "conditions", "signs", "assessments", "interventions", "relations"],
  "properties": {
    "meta": {
      "type": "object",
      "required": ["name", "version", "language", "created_at", "scope"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "language": { "type": "string" },
        "created_at": { "type": "string" },
        "scope": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "domains": {
      "type": "array",
      "items": { "$ref": "#/$defs/domain" }
    },
    "conditions": {
      "type": "array",
      "items": { "$ref": "#/$defs/condition" }
    },
    "signs": {
      "type": "array",
      "items": { "$ref": "#/$defs/sign" }
    },
    "assessments": {
      "type": "array",
      "items": { "$ref": "#/$defs/assessment" }
    },
    "interventions": {
      "type": "array",
      "items": { "$ref": "#/$defs/intervention" }
    },
    "relations": {
      "type": "array",
      "items": { "$ref": "#/$defs/relation" }
    }
  },
  "$defs": {
    "snakeId": {
      "type": "string",
      "pattern": "^[a-z0-9]+(?:_[a-z0-9]+)*$"
    },
    "domain": {
      "type": "object",
      "required": ["id", "label", "description"],
      "properties": {
        "id": { "$ref": "#/$defs/snakeId" },
        "label": { "type": "string" },
        "description": { "type": "string" }
      },
      "additionalProperties": true
    },
    "condition": {
      "type": "object",
      "required": ["id", "label", "aliases", "category", "affects_domains"],
      "properties": {
        "id": { "$ref": "#/$defs/snakeId" },
        "label": { "type": "string" },
        "aliases": {
          "type": "array",
          "items": { "type": "string" }
        },
        "category": { "type": "string" },
        "affects_domains": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/snakeId" }
        }
      },
      "additionalProperties": true
    },
    "sign": {
      "type": "object",
      "required": ["id", "label", "related_domains"],
      "properties": {
        "id": { "$ref": "#/$defs/snakeId" },
        "label": { "type": "string" },
        "related_domains": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/snakeId" }
        }
      },
      "additionalProperties": true
    },
    "assessment": {
      "type": "object",
      "required": ["id", "label", "type", "target_domains"],
      "properties": {
        "id": { "$ref": "#/$defs/snakeId" },
        "label": { "type": "string" },
        "type": { "type": "string" },
        "target_domains": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/snakeId" }
        }
      },
      "additionalProperties": true
    },
    "intervention": {
      "type": "object",
      "required": ["id", "label", "type", "target_domains", "indications"],
      "properties": {
        "id": { "$ref": "#/$defs/snakeId" },
        "label": { "type": "string" },
        "type": { "type": "string" },
        "target_domains": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/snakeId" }
        },
        "indications": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/snakeId" }
        }
      },
      "additionalProperties": true
    },
    "relation": {
      "type": "object",
      "required": ["type", "from", "to"],
      "properties": {
        "type": { "type": "string" },
        "from": { "type": "string" },
        "to": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}
