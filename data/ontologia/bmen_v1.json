      "category": "neurodesenvolvimento",
      "affects_domains": ["atencao_executivo", "regulacao_emocional", "interacao_social"]
    },
    {
      "id": "transtorno_ansiedade",
      "label": "Transtorno de Ansiedade",
      "aliases": ["Ansiedade"],
      "category": "ansiedade",
      "affects_domains": ["regulacao_emocional", "interacao_social", "atencao_executivo"]
    }
  ],
  "signs": [
    {
      "id": "hipersensibilidade_a_som",
      "label": "Hipersensibilidade a som",
